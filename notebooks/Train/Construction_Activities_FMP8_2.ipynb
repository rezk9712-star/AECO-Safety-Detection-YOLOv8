18a. Capture 3–5 Annotation Example Screenshots

[ ]
import os
import glob
import matplotlib.pyplot as plt
import matplotlib.patches as patches
from PIL import Image as PILImage
from IPython.display import Image, display

annot_img_dir   = '/content/Construction-Activities---FMP8-2/valid/images/'
annot_label_dir = '/content/Construction-Activities---FMP8-2/valid/labels/'
evidence_dir    = '/results/evidence'
os.makedirs(evidence_dir, exist_ok=True)

COLORS = plt.cm.get_cmap('tab10').colors
val_imgs = sorted(glob.glob(os.path.join(annot_img_dir, '*.jpg')))[:5]

for idx, img_path in enumerate(val_imgs, 1):
    img     = PILImage.open(img_path).convert('RGB')
    W, H    = img.size
    fig, ax = plt.subplots(1, figsize=(10, 6))
    ax.imshow(img)

    label_file = os.path.join(
        annot_label_dir,
        os.path.splitext(os.path.basename(img_path))[0] + '.txt'
    )
    if os.path.exists(label_file):
        with open(label_file) as lf:
            for line in lf:
                parts = line.strip().split()
                if len(parts) < 5:
                    continue
                cls_id, cx, cy, bw, bh = int(parts[0]), float(parts[1]), float(parts[2]), float(parts[3]), float(parts[4])
                x1 = (cx - bw / 2) * W
                y1 = (cy - bh / 2) * H
                rect = patches.Rectangle(
                    (x1, y1), bw * W, bh * H,
                    linewidth=2, edgecolor=COLORS[cls_id % len(COLORS)], facecolor='none'
                )
                ax.add_patch(rect)
                cls_name = model.names.get(cls_id, str(cls_id))
                ax.text(x1, y1 - 4, cls_name, color=COLORS[cls_id % len(COLORS)],
                        fontsize=9, backgroundcolor='black')

    ax.axis('off')
    ax.set_title(f'Annotation Example {idx}: {os.path.basename(img_path)}', fontsize=11)

    # Flat file: annotation_examples_01.png, annotation_examples_02.png ...
    save_path = os.path.join(evidence_dir, f'annotation_examples_{idx:02d}.png')
    plt.savefig(save_path, bbox_inches='tight', dpi=150)
    plt.show()
    plt.close()
    print(f'✅ Saved: {save_path}')

print(f'\n✅ {len(val_imgs)} annotation screenshots saved flat in {evidence_dir}')


18b. Capture 10 Validation Set Prediction Screenshots

[ ]
import os
import glob
import shutil
from IPython.display import Image, display
from ultralytics import YOLO

model = YOLO('/content/runs/detect/train2/weights/best.pt')

val_img_dir = '/content/Construction-Activities---FMP8-2/valid/images/'
val_images  = sorted(glob.glob(os.path.join(val_img_dir, '*.jpg')))[:10]

evidence_dir = '/results/evidence'
os.makedirs(evidence_dir, exist_ok=True)

# Temp dir for YOLO save output, then rename to flat files
_tmp = '/results/_tmp_val'
os.makedirs(_tmp, exist_ok=True)

print(f'Running inference on {len(val_images)} validation images...\n')
for i, img_path in enumerate(val_images, 1):
    results = model.predict(
        img_path, conf=0.25, save=True,
        project=_tmp, name=f'pred_{i:02d}', exist_ok=True
    )
    # YOLO saves annotated image inside _tmp/pred_XX/<filename>
    saved = glob.glob(os.path.join(_tmp, f'pred_{i:02d}', '*'))
    if saved:
        dst = os.path.join(evidence_dir, f'val_predictions_{i:02d}.png')
        shutil.copy(saved[0], dst)
        print(f'✅ val_predictions_{i:02d}.png')
    for r in results:
        for box in r.boxes:
            print(f'  → {model.names[int(box.cls)]}: {float(box.conf):.2f}')
    display(Image(img_path))

shutil.rmtree(_tmp, ignore_errors=True)
print(f'\n✅ 10 validation screenshots saved flat in {evidence_dir}')


